{
  "name": "insight-to-action",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "cd apps/backend && uvicorn app.main:app --reload",
    "dev:frontend": "cd apps/frontend-web && npm run dev",
    "build:frontend": "cd apps/frontend-web && npm run build"
  }
}
